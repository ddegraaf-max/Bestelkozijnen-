PORT=3000
SESSION_SECRET=verzin-een-lange-willekeurige-string

# Publieke URL van de site (gebruikt voor de link in de wachtwoord-herstelmail).
# Laat leeg om automatisch het verzoek-adres te gebruiken.
PUBLIC_URL=https://bestelkozijnenopmaat.nl

# Beheerder (wordt 1x aangemaakt bij start als hij nog niet bestaat)
ADMIN_EMAIL=montage@creditline.nl
ADMIN_PASSWORD=kiesEenSterkWachtwoord

# Database (PostgreSQL). Op Railway: koppel de Postgres-service, dan staat
# DATABASE_URL automatisch klaar (Variables -> Add Reference -> Postgres
# DATABASE_URL). Laat leeg om lokaal de JSON-bestandsopslag te gebruiken.
DATABASE_URL=

# Opslag voor geüploade PDF-offertes (mount op Railway een volume op dit pad
# voor blijvende bestanden). De database bewaart alleen de bestandsnaam.
DATA_DIR=/data

# AI-configuratie- & inmeet-assistent (OpenAI). gpt-4o-mini is zeer goedkoop
# ($0,15/$0,60 per 1M tokens) en ruim voldoende. Klant zonder sleutel ziet de
# assistent niet. Maak een sleutel op platform.openai.com.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# E-mail (Resend) — optioneel
RESEND_API_KEY=
MAIL_FROM=noreply@bestelkozijnenopmaat.nl
MAIL_TO=montage@creditline.nl
