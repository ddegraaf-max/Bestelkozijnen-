<%- include('partials/header') %>
<section class="wrap block" style="padding-top:36px">
  <a href="/beheer" class="muted-link">&larr; Terug naar beheer</a>
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin:12px 0 18px">
    <h1 style="font-size:30px">Aanvraag <%= r.ref %></h1>
    <span class="status <%= r.status %>"><%= STATUS_LABELS[r.status] %></span>
  </div>

  <table class="spec-table" style="margin-bottom:16px">
    <tr><th colspan="2">Klant</th></tr>
    <tr><td>Naam</td><td><%= r.klant.naam %></td></tr>
    <tr><td>E-mail</td><td><%= r.klant.email %></td></tr>
    <tr><td>Telefoon</td><td><%= r.klant.telefoon || '-' %></td></tr>
  </table>

  <% r.elementen.forEach(function(e,i){ %>
    <%- include('partials/element_spec', { e: e, i: i }) %>
  <% }) %>
  <% if (r.klant.opmerking) { %><p style="color:var(--muted);font-size:14px;margin-bottom:18px"><strong>Opmerking:</strong> <%= r.klant.opmerking %></p><% } %>

  <div class="card" style="margin-bottom:14px">
    <h3 style="font-size:17px">Offerte voor de klant</h3>
    <p style="color:var(--muted);font-size:13.5px;margin-top:6px">Vul de prijs in en voeg eventueel een PDF toe. Met <strong>Concept opslaan</strong> wordt er <em>niets</em> verstuurd — de klant krijgt pas bericht als je op <strong>Opslaan &amp; versturen</strong> klikt. Dan gaan prijs, notitie én PDF in één e-mail mee.</p>
    <form method="POST" action="/beheer/aanvraag/<%= r.id %>/offerte" enctype="multipart/form-data" style="margin-top:14px">
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
        <label style="flex:0 0 160px">
          <span style="display:block;font-size:13px;color:var(--muted);margin-bottom:4px">Bedrag (€)</span>
          <input name="prijs" type="number" step="0.01" min="0" value="<%= r.prijs != null ? r.prijs : '' %>" placeholder="0,00" style="width:100%;padding:11px;border:1.5px solid var(--line-strong);border-radius:10px">
        </label>
        <label style="flex:1;min-width:220px">
          <span style="display:block;font-size:13px;color:var(--muted);margin-bottom:4px">Notitie voor de klant (optioneel)</span>
          <input name="notitie" type="text" maxlength="500" value="<%= r.prijsNotitie || '' %>" placeholder="bijv. incl. montage en BTW, geldig 30 dagen" style="width:100%;padding:11px;border:1.5px solid var(--line-strong);border-radius:10px">
        </label>
      </div>
      <label style="display:block;margin-top:12px">
        <span style="display:block;font-size:13px;color:var(--muted);margin-bottom:4px">Offerte-PDF (optioneel — vervangt een eerder geüploade)</span>
        <input type="file" name="offerte" accept="application/pdf" style="font-size:13px">
      </label>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px">
        <button class="btn btn-ghost" name="actie" value="concept">Concept opslaan</button>
        <button class="btn btn-primary" name="actie" value="versturen">Opslaan &amp; versturen naar klant</button>
      </div>
    </form>
    <div style="margin-top:10px;font-size:13px;color:var(--ok)">
      <% if (r.prijs != null) { %><div>&#10003; Prijs: &euro; <%= r.prijs.toLocaleString('nl-NL', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %><%= r.prijsNotitie ? ' — ' + r.prijsNotitie : '' %></div><% } %>
      <% if (r.offertePdf) { %><div>&#10003; PDF geüpload</div><% } %>
    </div>
  </div>

  <div class="card">
    <h3 style="font-size:17px">Status wijzigen</h3>
    <p style="color:var(--muted);font-size:13.5px;margin-top:6px">Bij elke statuswijziging krijgt de klant automatisch een e-mail.</p>
    <form method="POST" action="/beheer/aanvraag/<%= r.id %>/status" style="margin-top:12px;display:flex;gap:8px;max-width:420px">
      <select name="status" style="flex:1;padding:11px;border:1.5px solid var(--line-strong);border-radius:10px;font-family:var(--font-body)">
        <% Object.keys(STATUS_LABELS).forEach(function(s){ %>
          <option value="<%= s %>" <%= r.status===s?'selected':'' %>><%= STATUS_LABELS[s] %></option>
        <% }) %>
      </select>
      <button class="btn btn-dark">Opslaan</button>
    </form>
  </div>
</section>
<%- include('partials/footer') %>
