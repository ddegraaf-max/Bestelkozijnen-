<%- include('partials/header') %>
<section class="wrap block narrow" style="padding-top:48px">
  <div class="auth-card">
    <h1>Tweestapsverificatie<% if (reconfig) { %> opnieuw instellen<% } %></h1>
    <p class="sub">Beveilig je account met een authenticator-app. Dit is <strong>optioneel</strong> — je kunt het later altijd aan- of uitzetten bij je accountinstellingen.</p>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>

    <ol style="margin:14px 0 6px;padding-left:20px;font-size:14px;line-height:1.6">
      <li><strong>Open eerst je authenticator-app</strong> (Google Authenticator, Microsoft Authenticator, Authy of 1Password) en tik daarin op <strong>+ / Scan QR-code</strong>.</li>
      <li>Scan de code hieronder <em>vanuit de app</em>, niet met de gewone iPhone-camera.</li>
      <li>Vul ter bevestiging de 6-cijferige code in.</li>
    </ol>
    <p class="muted" style="font-size:12px;margin:0 0 8px">Op iPhone biedt de camera soms &ldquo;Verificatiecode in Wachtwoorden&rdquo; aan — dat is Apple&rsquo;s eigen authenticator en werkt ook prima. Wil je per se Google Authenticator gebruiken, open dan eerst die app en scan van daaruit.</p>

    <div style="display:flex;flex-direction:column;align-items:center;gap:14px;margin:18px 0">
      <% if (qr) { %><img src="<%= qr %>" alt="QR-code voor authenticator" width="220" height="220" style="border:1px solid var(--line);border-radius:10px;background:#fff;padding:6px"><% } %>
      <% if (typeof otpauth !== 'undefined' && otpauth) { %>
        <a href="<%= otpauth %>" class="btn btn-ghost" style="font-size:14px">Open in mijn authenticator-app</a>
        <div class="muted" style="font-size:11px;margin-top:-6px">(handig op je telefoon — opent je standaard authenticator)</div>
      <% } %>
      <div style="text-align:center">
        <div class="muted" style="font-size:12px;margin-bottom:4px">Lukt scannen niet? Voer deze sleutel handmatig in:</div>
        <code style="font-family:var(--font-mono);font-size:13px;letter-spacing:.12em;background:var(--panel-2);padding:6px 10px;border-radius:8px;display:inline-block;word-break:break-all"><%= secret %></code>
      </div>
    </div>

    <form method="POST" action="/2fa/instellen">
      <div class="fld"><label>Code uit je app</label><input name="code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9 ]*" maxlength="7" placeholder="123 456" autofocus style="letter-spacing:.3em;font-family:var(--font-mono);font-size:18px;text-align:center"></div>
      <button class="btn btn-primary" style="width:100%">Bevestigen &amp; activeren</button>
    </form>
    <p class="muted-link" style="margin-top:16px">
      <% if (reconfig) { %><a href="/portaal/account">Terug naar instellingen</a><% } else { %><a href="/portaal">Dit later doen &rarr; naar mijn portaal</a><% } %>
    </p>
  </div>
</section>
<%- include('partials/footer') %>
