<%- include('partials/header') %>

<section class="wrap hero" style="padding-bottom:18px">
  <span class="eyebrow"><b></b>Contact</span>
  <h1 style="margin-top:16px">Neem contact op</h1>
  <p class="lead">Vragen over je kozijnen of je bestelling? We helpen je graag verder.</p>
</section>

<section class="wrap block" style="padding-top:10px">
  <div class="contact-grid">
    <div class="card">
      <h3>Gegevens</h3>
      <p class="co" style="margin-top:12px;line-height:1.9;color:var(--muted)">
        <b style="color:var(--ink)"><%= company.legalName %></b><br>
        <%= company.address %><br><br>
        Telefoon: <a href="tel:<%= company.phone.replace(/\s/g,'') %>" style="color:var(--accent-ink)"><%= company.phone %></a><br>
        E-mail: <a href="mailto:<%= company.email %>" style="color:var(--accent-ink)"><%= company.email %></a><br><br>
        KVK: <%= company.kvk %><br>
        BTW: <%= company.btw %>
      </p>
      <div class="contact-facts" style="margin-top:18px">
        <div class="fact"><span class="fk">Bereikbaarheid</span><span class="fv">Telefonisch ma&ndash;za <b>09:00&ndash;17:00</b></span></div>
        <div class="fact"><span class="fk">E-mail</span><span class="fv">Reactie meestal binnen <b>1 werkdag</b></span></div>
        <div class="fact"><span class="fk">Offerte</span><span class="fv">Meestal binnen <b>15 min</b> in je beveiligde portaal (met tweestapsverificatie)</span></div>
        <div class="fact"><span class="fk">Werkgebied</span><span class="fv">Heel <b>Nederland</b> &mdash; levering door het hele land, montage op aanvraag</span></div>
        <div class="fact"><span class="fk">Bezoek</span><span class="fv">Alleen op afspraak</span></div>
      </div>
      <iframe title="Kaart &mdash; <%= company.address %>" style="width:100%;height:220px;border:0;border-radius:12px;margin-top:16px" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps?q=<%= encodeURIComponent(company.address) %>&output=embed"></iframe>
      <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(company.address) %>" target="_blank" rel="noopener noreferrer" style="display:inline-block;margin-top:10px;color:var(--accent-ink);font-weight:600">Routebeschrijving &rarr;</a>
    </div>
    <div class="card">
      <h3>Stuur een bericht</h3>
      <div class="fld" style="margin-top:12px"><label>Naam *</label><input id="naam" placeholder="Je naam"></div>
      <div class="fld"><label>E-mail *</label><input id="email" type="email" placeholder="jij@voorbeeld.nl"></div>
      <div class="fld"><label>Bericht</label><textarea id="bericht" style="min-height:90px" placeholder="Waar kunnen we mee helpen?"></textarea></div>
      <input id="hp_website" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;opacity:0">
      <button class="btn btn-primary" id="sendBtn" style="width:100%">Versturen</button>
      <p id="formMsg" style="margin-top:10px;font-family:var(--font-mono);font-size:13px"></p>
    </div>
  </div>
</section>

<script>
var __formLoaded = Date.now();
document.getElementById('sendBtn').addEventListener('click', async function(){
  const msg=document.getElementById('formMsg');
  const payload={naam:naam.value,email:email.value,bericht:bericht.value,samenvatting:'Contactformulier',website:document.getElementById('hp_website').value,elapsed:Date.now()-__formLoaded};
  if(!payload.naam||!payload.email){msg.style.color='var(--accent-ink)';msg.textContent='Vul minimaal naam en e-mail in.';return;}
  this.disabled=true;msg.style.color='var(--muted)';msg.textContent='Versturen…';
  try{
    const r=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const d=await r.json();
    if(d.ok){msg.style.color='var(--ok)';msg.textContent='✓ Bedankt voor je bericht!';}
    else{msg.style.color='var(--accent-ink)';msg.textContent=d.error||'Er ging iets mis.';this.disabled=false;}
  }catch(e){msg.style.color='var(--accent-ink)';msg.textContent='Verbinding mislukt.';this.disabled=false;}
});
</script>

<%- include('partials/footer') %>
