<body>
<div style="background:#faf8f4;border-bottom:1px solid #d8d2c4;padding:14px 24px;font-family:sans-serif">
  <a href="/" style="text-decoration:none;color:#161616;font-weight:800;font-size:17px">bestelkozijnen<span style="color:#e8590c">opmaat</span>.nl</a>
</div>
<% } %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
/* Alle scan-styling in eigen kz-naamruimte — botst nooit met de site-CSS */
.kz-wrap{
  --kz-ink:#161616; --kz-ink-soft:#6b6459; --kz-paper:#f5f2ec; --kz-card:#fcfbf8;
  --kz-line:#e5e0d5; --kz-line-strong:#d8d2c4; --kz-accent:#e8590c; --kz-accent-soft:#fdece1;
  --kz-ok:#2b8a3e; --kz-warn:#e67700; --kz-low:#c92a2a; --kz-mono:'JetBrains Mono',monospace;
  color:var(--kz-ink);
  max-width:960px;margin:0 auto;padding:36px 20px 90px;box-sizing:border-box;
}
.kz-wrap *{box-sizing:border-box}
/* Site-CSS heeft fade/reveal-effecten op algemene elementen; die laten de
   scan-onderdelen half doorzichtig hangen. Forceer volle dekking. */
#kz-scan, #kz-scan *:not(.kz-spin){opacity:1 !important;filter:none !important;animation:none !important}
#kz-scan .kz-step{color:#6b6459 !important}
.kz-h1{font-family:'Archivo','Hanken Grotesk',sans-serif;font-weight:800;font-size:clamp(30px,5vw,44px);line-height:1.05;letter-spacing:-.02em;margin:0}
.kz-intro{margin:10px 0 0;max-width:620px;font-size:16px;line-height:1.55}
.kz-steps{display:flex;gap:8px;flex-wrap:wrap;margin-top:18px}
.kz-step{font-family:var(--kz-mono);font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--kz-ink-soft);
  background:var(--kz-card);border:1px solid var(--kz-line-strong);border-radius:999px;padding:7px 13px}
.kz-step b{color:var(--kz-accent)}
.kz-panel{background:var(--kz-card);border:1px solid var(--kz-line-strong);border-radius:12px;margin-top:26px;overflow:hidden;box-shadow:0 1px 0 rgba(22,22,22,.04)}
.kz-panel-h{padding:16px 22px;border-bottom:1px solid var(--kz-line)}
.kz-panel-h h2{font-size:12px;font-family:var(--kz-mono);text-transform:uppercase;letter-spacing:.1em;color:var(--kz-ink-soft);font-weight:400;margin:0}
.kz-panel-b{padding:22px}
.kz-drop{border:2px dashed var(--kz-line-strong);border-radius:10px;padding:38px 20px;text-align:center;cursor:pointer;transition:.15s;background:var(--kz-paper)}
.kz-drop:hover,.kz-drop.kz-over{border-color:var(--kz-accent);background:var(--kz-accent-soft)}
.kz-drop b{font-size:17px;font-weight:600}
.kz-drop p{color:var(--kz-ink-soft);font-size:13px;margin:5px 0 0}
.kz-thumbs{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px}
.kz-thumb{position:relative;width:120px}
.kz-thumb img{width:120px;height:92px;object-fit:cover;border:1px solid var(--kz-line-strong);border-radius:8px;display:block}
.kz-thumb .kz-rm{position:absolute;top:-7px;right:-7px;background:var(--kz-ink);color:#fff;border:none;width:22px;height:22px;border-radius:50%;cursor:pointer;font-size:11px;line-height:1}
.kz-thumb .kz-st{font-family:var(--kz-mono);font-size:9.5px;margin-top:4px;color:var(--kz-ink-soft);display:block}
.kz-btn{font-family:inherit;font-weight:600;font-size:15px;background:var(--kz-ink);color:#fff;
  border:none;border-radius:999px;padding:13px 26px;cursor:pointer;transition:.15s;display:inline-block;text-decoration:none}
.kz-btn:hover{background:#000;transform:translateY(-1px)}
.kz-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.kz-btn.kz-accent{background:var(--kz-accent)}
.kz-btn.kz-accent:hover{background:#d14e08}
.kz-btn.kz-ghost{background:transparent;color:var(--kz-ink);border:1.5px solid var(--kz-ink)}
.kz-btn.kz-small{font-size:13px;padding:9px 16px}
.kz-row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-top:18px}
.kz-spin{display:inline-block;width:15px;height:15px;border:2.5px solid rgba(255,255,255,.35);border-top-color:#fff;border-radius:50%;animation:kzsp .7s linear infinite;vertical-align:-3px;margin-right:8px}
@keyframes kzsp{to{transform:rotate(360deg)}}
.kz-status{font-family:var(--kz-mono);font-size:12px;color:var(--kz-ink-soft)}
.kz-field{margin-top:16px}
.kz-field label{display:block;font-family:var(--kz-mono);font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--kz-ink-soft);margin-bottom:6px}
.kz-field input,.kz-field textarea{width:100%;font-family:inherit;font-size:14px;padding:11px 13px;border:1px solid var(--kz-line-strong);border-radius:8px;background:var(--kz-paper);color:var(--kz-ink)}
.kz-field input:focus,.kz-field textarea:focus{outline:2px solid var(--kz-accent);border-color:var(--kz-accent)}
.kz-hint{font-size:12px;color:var(--kz-ink-soft);margin-top:5px}
.kz-grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:600px){.kz-grid2{grid-template-columns:1fr}}
.kz-wrap table{width:100%;border-collapse:collapse;font-size:14px}
.kz-wrap th{font-family:var(--kz-mono);font-size:10px;text-transform:uppercase;letter-spacing:.08em;text-align:left;color:var(--kz-ink-soft);padding:9px 8px;border-bottom:1px solid var(--kz-line-strong);font-weight:400}
.kz-wrap td{padding:9px 8px;border-bottom:1px solid var(--kz-line);vertical-align:middle}
.kz-wrap td input,.kz-wrap td select{font-family:var(--kz-mono);font-size:13px;border:1px solid var(--kz-line-strong);border-radius:6px;background:var(--kz-paper);padding:8px;width:100%;color:var(--kz-ink)}
.kz-wrap td input:focus,.kz-wrap td select:focus{outline:2px solid var(--kz-accent)}
.kz-conf{font-family:var(--kz-mono);font-size:9.5px;padding:3px 9px;border-radius:999px;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap}
.kz-conf.hoog{background:#e6f4e8;color:var(--kz-ok)}
.kz-conf.middel{background:#fff4e0;color:var(--kz-warn)}
.kz-conf.laag{background:#ffe6e6;color:var(--kz-low)}
.kz-opm{font-size:12px;color:var(--kz-ink-soft);margin-top:2px}
.kz-delrow{background:none;border:1px solid var(--kz-line-strong);border-radius:6px;color:var(--kz-low);cursor:pointer;padding:6px 9px;font-size:12px}
.kz-note{background:var(--kz-accent-soft);border-radius:8px;padding:13px 15px;font-size:13px;margin-top:16px;line-height:1.55}
.kz-err{background:#ffe6e6;border-radius:8px;padding:13px 15px;font-size:13px;margin-top:14px;color:var(--kz-low)}
.kz-hidden{display:none!important}
.kz-done{text-align:center;padding:50px 20px}
.kz-done .kz-check{width:66px;height:66px;border-radius:50%;background:var(--kz-ok);color:#fff;font-size:32px;display:flex;align-items:center;justify-content:center;margin:0 auto 18px}
.kz-done h2{font-size:26px;font-weight:800;margin:0}
.kz-done p{color:var(--kz-ink-soft);margin:10px auto 0;max-width:480px;line-height:1.55}
.kz-done .kz-nr{font-family:var(--kz-mono);background:var(--kz-paper);border:1px solid var(--kz-line-strong);border-radius:8px;padding:8px 16px;display:inline-block;margin-top:14px;font-size:14px}
.kz-usp{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-top:26px}
.kz-usp .kz-u{background:var(--kz-card);border:1px solid var(--kz-line);border-radius:10px;padding:16px 18px;font-size:13px;line-height:1.5;color:var(--kz-ink-soft)}
.kz-usp .kz-u b{display:block;color:var(--kz-ink);font-size:14px;margin-bottom:4px}
</style>

<div class="kz-wrap" id="kz-scan">

<div class="kz-hero" style="opacity:1 !important;filter:none !important">
  <div role="heading" aria-level="1" class="kz-h1" style="color:#161616 !important;-webkit-text-fill-color:#161616 !important;text-shadow:none !important;background:none !important;opacity:1 !important;filter:none !important">AI Kozijnen<span style="color:#e8590c !important;-webkit-text-fill-color:#e8590c !important">scan</span></div>
  <div class="kz-intro" style="color:#4a463d !important;-webkit-text-fill-color:#4a463d !important;text-shadow:none !important;opacity:1 !important;filter:none !important">Upload een foto van uw gevel en onze AI herkent binnen een minuut al uw kozijnen — inclusief geschatte afmetingen. U ontvangt daarna snel een richtprijs, geheel vrijblijvend.</div>
  <div class="kz-steps">
    <span class="kz-step"><b>1</b> Foto uploaden</span>
    <span class="kz-step"><b>2</b> AI herkent kozijnen</span>
    <span class="kz-step"><b>3</b> Controleer maten</span>
    <span class="kz-step"><b>4</b> Ontvang richtprijs</span>
  </div>
</div>

<!-- STAP 1: UPLOAD -->
<section class="kz-panel" id="kzUploadPanel">
  <div class="kz-panel-h"><h2>Stap 1 — Foto's van uw gevel</h2></div>
  <div class="kz-panel-b">
    <div class="kz-drop" id="kzDrop">
      <b>Sleep foto's hierheen of klik om te kiezen</b>
      <p>Fotografeer de gevel recht van voren, bij daglicht. Maximaal 3 foto's (JPG/PNG).</p>
    </div>
    <input type="file" id="kzFileInput" accept="image/jpeg,image/png,image/webp" multiple class="kz-hidden">
    <div class="kz-thumbs" id="kzThumbs"></div>

    <div class="kz-field">
      <label>Weet u toevallig één maat? (niet verplicht, wel nauwkeuriger)</label>
      <input type="text" id="kzRefMaat" placeholder='Bijvoorbeeld: "de voordeur is 231 cm hoog" of "het raam links is 180 cm breed"'>
    </div>

    <div class="kz-row">
      <button class="kz-btn kz-accent" id="kzAnalyzeBtn" disabled>Start de scan &rarr;</button>
      <span class="kz-status" id="kzStatus"></span>
    </div>
    <div class="kz-err kz-hidden" id="kzErrBox"></div>
  </div>
</section>

<!-- STAP 2: RESULTATEN -->
<section class="kz-panel kz-hidden" id="kzResultsPanel">
  <div class="kz-panel-h"><h2>Stap 2 — Uw herkende kozijnen (pas gerust aan)</h2></div>
  <div class="kz-panel-b">
    <div style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th style="min-width:170px">Kozijn</th>
          <th style="min-width:115px">Type</th>
          <th style="width:100px">Breedte (mm)</th>
          <th style="width:100px">Hoogte (mm)</th>
          <th style="width:90px">Zekerheid</th>
          <th style="width:44px"></th>
        </tr>
      </thead>
      <tbody id="kzResultsBody"></tbody>
    </table>
    </div>
    <div class="kz-row">
      <button class="kz-btn kz-ghost kz-small" id="kzAddRowBtn">+ Kozijn toevoegen</button>
    </div>
    <div class="kz-note">De afmetingen zijn een <b>schatting op basis van uw foto</b>. Klopt een maat niet helemaal? Pas hem gerust aan — of laat het zo, wij meten vóór de definitieve offerte altijd gratis bij u in.</div>
  </div>
</section>

<!-- STAP 3: GEGEVENS -->
<section class="kz-panel kz-hidden" id="kzFormPanel">
  <div class="kz-panel-h"><h2>Stap 3 — Uw gegevens voor de richtprijs</h2></div>
  <div class="kz-panel-b">
    <div class="kz-grid2">
      <div class="kz-field"><label>Naam *</label><input type="text" id="kzNaam" autocomplete="name"></div>
      <div class="kz-field"><label>E-mailadres *</label><input type="email" id="kzEmail" autocomplete="email"></div>
      <div class="kz-field"><label>Telefoon</label><input type="tel" id="kzTel" autocomplete="tel"></div>
      <div class="kz-field"><label>Adres / plaats</label><input type="text" id="kzAdres" autocomplete="street-address"></div>
    </div>
    <div class="kz-field"><label>Opmerkingen (kleurwens, beglazing, planning…)</label><textarea id="kzOpm" rows="3"></textarea></div>
    <div class="kz-row">
      <button class="kz-btn kz-accent" id="kzSubmitBtn">Vraag richtprijs aan &rarr;</button>
      <span class="kz-status">Vrijblijvend · reactie meestal binnen 1 werkdag</span>
    </div>
    <div class="kz-err kz-hidden" id="kzFormErr"></div>
    <p class="kz-hint" style="margin-top:14px">Wij gebruiken uw gegevens uitsluitend voor deze aanvraag. Zie ons <a href="/privacybeleid" style="color:inherit">privacybeleid</a>.</p>
  </div>
</section>

<!-- KLAAR -->
<section class="kz-panel kz-hidden" id="kzDonePanel">
  <div class="kz-done">
    <div class="kz-check">&#10003;</div>
    <h2>Aanvraag ontvangen!</h2>
    <p>Bedankt! Wij bekijken uw scan en sturen u zo snel mogelijk een richtprijs op basis van de geschatte afmetingen. De definitieve offerte volgt na een gratis en vrijblijvende inmeting bij u thuis.</p>
    <div class="kz-nr" id="kzDoneNr"></div>
  </div>
</section>

<div class="kz-usp">
  <div class="kz-u"><b>Binnen 1 minuut resultaat</b>Geen afspraken of opmeetwerk nodig voor uw eerste prijsindicatie.</div>
  <div class="kz-u"><b>Vrijblijvend &amp; gratis</b>De scan en richtprijs kosten niets. Inmeten doen wij ook gratis.</div>
  <div class="kz-u"><b>A-merk profielen op maat</b>Drutex &amp; Aluplast kozijnen — geleverd en gemonteerd door één partij.</div>
</div>

</div>

<script>
(function(){
/* ================= STATE ================= */
var photos = [];
var kozijnen = [];
var aiAlgemeen = '';
function $(id){ return document.getElementById(id); }
var BASE = '/ai-kozijnenscan';
var MAX_FOTO = 3;
var MAX_PX = 1600; // client-side resize: scheelt data én API-kosten

/* ================= UPLOAD + RESIZE ================= */
var drop = $('kzDrop'), fileInput = $('kzFileInput');
drop.addEventListener('click', function(){ fileInput.click(); });
drop.addEventListener('dragover', function(e){ e.preventDefault(); drop.classList.add('kz-over'); });
drop.addEventListener('dragleave', function(){ drop.classList.remove('kz-over'); });
drop.addEventListener('drop', function(e){ e.preventDefault(); drop.classList.remove('kz-over'); addFiles(e.dataTransfer.files); });
fileInput.addEventListener('change', function(e){ addFiles(e.target.files); });

function addFiles(list){
  Array.prototype.slice.call(list, 0, MAX_FOTO - photos.length).forEach(function(f){
    if(!/image\/(jpeg|png|webp)/.test(f.type)) return;
    resizeImage(f).then(function(resized){
      if(resized && resized.base64){ photos.push(resized); renderThumbs(); }
    });
  });
}

function resizeImage(file){
  return new Promise(function(resolve){
    var img = new Image();
    var url = URL.createObjectURL(file);
    img.onload = function(){
      var scale = Math.min(1, MAX_PX / Math.max(img.width, img.height));
      var w = Math.round(img.width * scale), h = Math.round(img.height * scale);
      var canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      URL.revokeObjectURL(url);
      var dataUrl = canvas.toDataURL('image/jpeg', 0.85);
      resolve({ name:file.name, dataUrl:dataUrl, base64:dataUrl.split(',')[1], mediaType:'image/jpeg', status:'gereed' });
    };
    img.onerror = function(){ URL.revokeObjectURL(url); resolve(null); };
    img.src = url;
  });
}

function renderThumbs(){
  $('kzThumbs').innerHTML = photos.map(function(p,i){ return '' +
    '<div class="kz-thumb">' +
      '<img src="'+p.dataUrl+'" alt="Foto '+(i+1)+'">' +
      '<button class="kz-rm" data-i="'+i+'">&#10005;</button>' +
      '<span class="kz-st">'+esc(p.name.slice(0,16))+' &middot; '+p.status+'</span>' +
    '</div>'; }).join('');
  Array.prototype.forEach.call(document.querySelectorAll('#kzThumbs .kz-rm'), function(btn){
    btn.addEventListener('click', function(){ photos.splice(+btn.getAttribute('data-i'),1); renderThumbs(); });
  });
  $('kzAnalyzeBtn').disabled = photos.length === 0;
}

/* ================= AI ANALYSE ================= */
$('kzAnalyzeBtn').addEventListener('click', analyzeAll);

function analyzeAll(){
  var btn = $('kzAnalyzeBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="kz-spin"></span>Uw gevel wordt gescand&hellip;';
  $('kzErrBox').classList.add('kz-hidden');
  photos.forEach(function(p){ p.status = 'scannen&hellip;'; }); renderThumbs();
  $('kzAnalyzeBtn').disabled = true;
  $('kzStatus').textContent = 'Dit duurt ongeveer 20-30 seconden…';

  fetch(BASE + '/analyse', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({
      images: photos.map(function(p){ return { base64: p.base64, mediaType: p.mediaType }; }),
      refMaat: $('kzRefMaat').value.trim()
    })
  }).then(function(r){ return r.json(); }).then(function(data){
    if(data.error) throw new Error(data.error);
    kozijnen = data.kozijnen || [];
    aiAlgemeen = data.algemeen || '';
    photos.forEach(function(p){ p.status = 'klaar &#10003;'; });
    $('kzStatus').textContent = kozijnen.length
      ? '\u2713 ' + kozijnen.length + ' kozijn(en) herkend'
      : 'Geen kozijnen herkend — probeer een duidelijkere foto of voeg ze handmatig toe';
    $('kzResultsPanel').classList.remove('kz-hidden');
    $('kzFormPanel').classList.remove('kz-hidden');
    renderRows();
    $('kzResultsPanel').scrollIntoView({behavior:'smooth'});
    afterAnalyze(btn);
  }).catch(function(e){
    photos.forEach(function(p){ p.status = 'fout'; });
    $('kzErrBox').textContent = e.message;
    $('kzErrBox').classList.remove('kz-hidden');
    $('kzStatus').textContent = '';
    afterAnalyze(btn);
  });
}
function afterAnalyze(btn){
  renderThumbs();
  btn.disabled = false;
  btn.textContent = 'Scan opnieuw';
}

/* ================= TABEL ================= */
function renderRows(){
  var types = ['vast','draai','draaikiep','klep','deur','pui','combinatie'];
  $('kzResultsBody').innerHTML = kozijnen.map(function(k,i){ return '' +
    '<tr>' +
      '<td><input data-i="'+i+'" data-f="oms" value="'+esc(k.oms)+'">' +
        (k.opm ? '<div class="kz-opm">'+esc(k.opm)+'</div>' : '') + '</td>' +
      '<td><select data-i="'+i+'" data-f="type">' +
        types.map(function(t){ return '<option'+(k.type===t?' selected':'')+'>'+t+'</option>'; }).join('') +
      '</select></td>' +
      '<td><input data-i="'+i+'" data-f="b" type="number" step="10" value="'+k.b+'"></td>' +
      '<td><input data-i="'+i+'" data-f="h" type="number" step="10" value="'+k.h+'"></td>' +
      '<td><span class="kz-conf '+k.conf+'">'+k.conf+'</span></td>' +
      '<td><button class="kz-delrow" data-i="'+i+'" title="Verwijderen">&#10005;</button></td>' +
    '</tr>'; }).join('');
  Array.prototype.forEach.call(document.querySelectorAll('#kzResultsBody [data-f]'), function(el){
    el.addEventListener('change', function(){
      var i = +el.getAttribute('data-i'), f = el.getAttribute('data-f');
      kozijnen[i][f] = (f==='b'||f==='h') ? +el.value : el.value;
    });
  });
  Array.prototype.forEach.call(document.querySelectorAll('#kzResultsBody .kz-delrow'), function(btn){
    btn.addEventListener('click', function(){ kozijnen.splice(+btn.getAttribute('data-i'),1); renderRows(); });
  });
}
$('kzAddRowBtn').addEventListener('click', function(){
  kozijnen.push({oms:'Kozijn '+(kozijnen.length+1),type:'vast',b:1000,h:1200,conf:'laag',opm:'zelf toegevoegd'});
  renderRows();
  $('kzFormPanel').classList.remove('kz-hidden');
});
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

/* ================= AANVRAAG VERSTUREN ================= */
$('kzSubmitBtn').addEventListener('click', function(){
  var btn = $('kzSubmitBtn');
  $('kzFormErr').classList.add('kz-hidden');
  if(!kozijnen.length){ showFormErr('Er zijn geen kozijnen in uw scan.'); return; }
  if(!$('kzNaam').value.trim() || !$('kzEmail').value.trim()){
    showFormErr('Vul in ieder geval uw naam en e-mailadres in.'); return;
  }
  btn.disabled = true;
  btn.innerHTML = '<span class="kz-spin"></span>Versturen&hellip;';
  fetch(BASE + '/aanvraag', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({
      naam: $('kzNaam').value.trim(),
      email: $('kzEmail').value.trim(),
      telefoon: $('kzTel').value.trim(),
      adres: $('kzAdres').value.trim(),
      opmerking: $('kzOpm').value.trim(),
      refMaat: $('kzRefMaat').value.trim(),
      algemeen: aiAlgemeen,
      items: kozijnen
    })
  }).then(function(r){ return r.json(); }).then(function(data){
    if(data.error) throw new Error(data.error);
    $('kzUploadPanel').classList.add('kz-hidden');
    $('kzResultsPanel').classList.add('kz-hidden');
    $('kzFormPanel').classList.add('kz-hidden');
    $('kzDoneNr').textContent = 'Aanvraagnummer: ' + data.nummer;
    $('kzDonePanel').classList.remove('kz-hidden');
    $('kzDonePanel').scrollIntoView({behavior:'smooth'});
  }).catch(function(e){
    showFormErr(e.message);
    btn.disabled = false;
    btn.innerHTML = 'Vraag richtprijs aan &rarr;';
  });
});
function showFormErr(msg){
  $('kzFormErr').textContent = msg;
  $('kzFormErr').classList.remove('kz-hidden');
}
})();
</script>

<% if (fp) { fp.forEach(function(p){ %><%- include(p) %><% }); } else { %>
</body>
</html>
<% } %>
