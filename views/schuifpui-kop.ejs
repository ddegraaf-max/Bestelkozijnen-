<%
// Echte site-header/footer als die gedetecteerd zijn; anders standalone fallback.
var hp = (typeof headerPartials !== 'undefined' && headerPartials && headerPartials.length) ? headerPartials : null;
%>
<% if (hp) { hp.forEach(function(p){ %><%- include(p) %><% }); } else { %>
<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'Schuifpuien' %> — bestelkozijnenopmaat.nl</title>
</head>
<body>
<div style="background:#faf8f4;border-bottom:1px solid #d8d2c4;padding:14px 24px;font-family:sans-serif">
  <a href="/" style="text-decoration:none;color:#161616;font-weight:800;font-size:17px">bestelkozijnen<span style="color:#e8590c">opmaat</span>.nl</a>
</div>
<% } %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
/* Alle schuifpui-styling in eigen sp-naamruimte — botst nooit met de site-CSS */
.sp-wrap{
  --sp-ink:#161616; --sp-soft:#6b6459; --sp-paper:#f5f2ec; --sp-card:#fcfbf8;
  --sp-line:#e5e0d5; --sp-line2:#d8d2c4; --sp-acc:#e8590c; --sp-acc-soft:#fdece1;
  --sp-glas:#dcebf2; --sp-glas2:#c8dfe9; --sp-staal:#3d434c;
  --sp-mono:'JetBrains Mono',monospace;
  color:var(--sp-ink);
  max-width:1160px;margin:0 auto;padding:40px 20px 90px;box-sizing:border-box;
  font-size:16px;line-height:1.6;
}
.sp-wrap *{box-sizing:border-box}
/* Site-CSS heeft fade/reveal-effecten; forceer volle dekking op deze sectie */
.sp-wrap, .sp-wrap *{opacity:1 !important;filter:none !important}
html::before,html::after,body::before,body::after,main::before,main::after{content:none !important;display:none !important}
header.site{position:sticky !important;top:0 !important;z-index:1000 !important}

.sp-kicker{font-family:var(--sp-mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--sp-acc);font-weight:600}
.sp-h1{font-family:'Archivo','Hanken Grotesk',sans-serif;font-weight:800;font-size:clamp(32px,5vw,50px);line-height:1.04;letter-spacing:-.02em;margin:10px 0 0}
.sp-h2{font-family:'Archivo','Hanken Grotesk',sans-serif;font-weight:800;font-size:clamp(23px,3.4vw,32px);line-height:1.1;letter-spacing:-.01em;margin:0}
.sp-lead{margin:16px 0 0;max-width:680px;font-size:17.5px;line-height:1.6;color:#3a362f}
.sp-sec{margin-top:64px}
.sp-sechead{display:flex;align-items:baseline;gap:16px;flex-wrap:wrap;margin-bottom:22px}
.sp-secnum{font-family:var(--sp-mono);font-size:12px;color:var(--sp-soft)}

.sp-grid{display:grid;gap:18px}
.sp-grid3{grid-template-columns:repeat(3,1fr)}
.sp-grid2{grid-template-columns:repeat(2,1fr)}
@media(max-width:900px){.sp-grid3{grid-template-columns:1fr}.sp-grid2{grid-template-columns:1fr}}

.sp-card{background:var(--sp-card);border:1px solid var(--sp-line2);border-radius:14px;padding:0;overflow:hidden;
  box-shadow:0 1px 0 rgba(22,22,22,.04);display:flex;flex-direction:column;text-decoration:none;color:var(--sp-ink);
  transition:border-color .15s, transform .15s}
a.sp-card:hover{border-color:var(--sp-acc);transform:translateY(-2px)}
.sp-card-vis{background:var(--sp-paper);border-bottom:1px solid var(--sp-line);padding:22px 22px 14px}
.sp-card-vis svg{display:block;width:100%;height:auto}
.sp-card-b{padding:18px 22px 22px;flex:1;display:flex;flex-direction:column}
.sp-tag{display:inline-block;align-self:flex-start;font-family:var(--sp-mono);font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;
  color:var(--sp-soft);background:var(--sp-paper);border:1px solid var(--sp-line2);border-radius:999px;padding:5px 11px}
.sp-card-b h3{font-size:19px;font-weight:700;margin:10px 0 6px;line-height:1.2}
.sp-card-b p{margin:0;font-size:14.5px;color:#3a362f;line-height:1.55;flex:1}
.sp-meer{margin-top:14px;font-weight:600;font-size:14.5px;color:var(--sp-acc)}

.sp-btn{display:inline-block;background:var(--sp-acc);color:#fff;text-decoration:none;font-weight:600;font-size:15.5px;
  border:none;border-radius:12px;padding:14px 26px;cursor:pointer;font-family:inherit}
.sp-btn:hover{background:#d14e08}
.sp-btn2{display:inline-block;background:var(--sp-ink);color:#fff;text-decoration:none;font-weight:600;font-size:15.5px;
  border:none;border-radius:12px;padding:14px 26px;cursor:pointer;font-family:inherit}
.sp-btn2:hover{background:#000}
.sp-btn-l{display:inline-block;color:var(--sp-acc);text-decoration:none;font-weight:600;font-size:15.5px;padding:14px 4px}

.sp-spec{width:100%;border-collapse:collapse;font-size:14.5px}
.sp-spec td{padding:11px 14px;border-bottom:1px solid var(--sp-line);vertical-align:top}
.sp-spec td:first-child{font-family:var(--sp-mono);font-size:11.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--sp-soft);white-space:nowrap;width:180px;padding-top:13px}
.sp-spec tr:last-child td{border-bottom:none}

.sp-stap{display:flex;gap:20px;padding:22px 0;border-bottom:1px solid var(--sp-line)}
.sp-stap:last-child{border-bottom:none}
.sp-stapnr{flex:0 0 46px;height:46px;border-radius:50%;background:var(--sp-ink);color:#fff;display:flex;align-items:center;justify-content:center;
  font-family:var(--sp-mono);font-size:15px;font-weight:600}
.sp-stap.sp-eerst .sp-stapnr{background:var(--sp-acc)}
.sp-stap h3{margin:2px 0 6px;font-size:18px;font-weight:700}
.sp-stap p{margin:0;font-size:15px;color:#3a362f;line-height:1.6;max-width:720px}

.sp-noot{background:var(--sp-acc-soft);border:1px solid #f3c4a4;border-radius:14px;padding:22px 26px;margin-top:26px}
.sp-noot b{color:#a13d05}

.sp-faq details{border-bottom:1px solid var(--sp-line);padding:4px 0}
.sp-faq summary{cursor:pointer;font-weight:600;font-size:16px;padding:14px 0;list-style:none;display:flex;justify-content:space-between;gap:14px}
.sp-faq summary::-webkit-details-marker{display:none}
.sp-faq summary:after{content:'+';font-family:var(--sp-mono);color:var(--sp-acc);font-size:18px}
.sp-faq details[open] summary:after{content:'\2013'}
.sp-faq details p{margin:0 0 16px;font-size:15px;color:#3a362f;max-width:760px}

.sp-form{background:var(--sp-card);border:1px solid var(--sp-line2);border-radius:16px;padding:30px;margin-top:26px}
.sp-fgrid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:700px){.sp-fgrid{grid-template-columns:1fr}}
.sp-veld{display:flex;flex-direction:column;gap:6px}
.sp-veld.sp-vol{grid-column:1 / -1}
.sp-veld label{font-family:var(--sp-mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--sp-soft)}
.sp-veld input,.sp-veld select,.sp-veld textarea{font-family:inherit;font-size:15px;color:var(--sp-ink);
  background:#fff;border:1px solid var(--sp-line2);border-radius:10px;padding:12px 14px;width:100%}
.sp-veld input:focus,.sp-veld select:focus,.sp-veld textarea:focus{outline:2px solid var(--sp-acc);border-color:var(--sp-acc)}
.sp-hp{position:absolute;left:-9999px;top:-9999px;height:0;overflow:hidden}
.sp-fmsg{margin-top:16px;font-size:15px;display:none;border-radius:10px;padding:14px 18px}
.sp-fmsg.sp-ok{display:block;background:#e6f4ea;border:1px solid #b7dfc2;color:#1e6b34}
.sp-fmsg.sp-fout{display:block;background:#fdecea;border:1px solid #f5c6c0;color:#a12a1e}

.sp-crumb{font-family:var(--sp-mono);font-size:11.5px;letter-spacing:.05em;color:var(--sp-soft);margin-bottom:18px}
.sp-crumb a{color:var(--sp-soft);text-decoration:none}
.sp-crumb a:hover{color:var(--sp-acc)}

.sp-split{display:grid;grid-template-columns:1.05fr .95fr;gap:36px;align-items:center}
@media(max-width:900px){.sp-split{grid-template-columns:1fr}}
.sp-illu{background:var(--sp-paper);border:1px solid var(--sp-line);border-radius:16px;padding:26px}
.sp-illu svg{display:block;width:100%;height:auto}
.sp-illu-cap{font-family:var(--sp-mono);font-size:11px;color:var(--sp-soft);text-align:center;margin-top:12px;letter-spacing:.04em}
</style>
