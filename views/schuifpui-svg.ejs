<%
// Gebruik: include('schuifpui-svg', { soort: 'hst' | 'psk' | 'alu' | 'latei' })
var s = (typeof soort !== 'undefined') ? soort : 'hst';
%>
<% if (s === 'hst') { %>
<svg viewBox="0 0 460 290" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Hef-schuifpui, tweedelig: rechterdeel schuift voor het vaste deel">
  <defs>
    <linearGradient id="spGlasA" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#e6f1f6"/><stop offset="1" stop-color="#c8dfe9"/>
    </linearGradient>
  </defs>
  <!-- kader -->
  <rect x="30" y="24" width="400" height="216" fill="none" stroke="#3a362f" stroke-width="10"/>
  <!-- vast deel links -->
  <rect x="44" y="38" width="182" height="188" fill="url(#spGlasA)" stroke="#3a362f" stroke-width="6"/>
  <line x1="52" y1="46" x2="120" y2="114" stroke="#fff" stroke-width="3" opacity=".55"/>
  <!-- schuivende vleugel rechts (ligt vóór het vaste deel) -->
  <g>
    <rect x="216" y="32" width="206" height="200" fill="#f5f2ec" stroke="#3a362f" stroke-width="0" opacity=".001"/>
    <rect x="218" y="34" width="200" height="196" fill="url(#spGlasA)" stroke="#161616" stroke-width="9"/>
    <line x1="232" y1="48" x2="316" y2="132" stroke="#fff" stroke-width="3" opacity=".55"/>
    <rect x="228" y="118" width="7" height="34" rx="3" fill="#161616"/>
  </g>
  <!-- schuifrichting -->
  <g stroke="#e8590c" stroke-width="5" fill="none" stroke-linecap="round">
    <line x1="360" y1="132" x2="266" y2="132"/>
    <path d="M282 118 266 132 282 146"/>
  </g>
  <!-- lage drempel + rails -->
  <rect x="30" y="240" width="400" height="10" fill="#3a362f"/>
  <line x1="40" y1="245" x2="420" y2="245" stroke="#f5f2ec" stroke-width="1.6" stroke-dasharray="10 7"/>
  <!-- maatlijn -->
  <g stroke="#6b6459" stroke-width="1.4">
    <line x1="30" y1="268" x2="430" y2="268"/>
    <line x1="30" y1="262" x2="30" y2="274"/><line x1="430" y1="262" x2="430" y2="274"/>
  </g>
  <text x="230" y="284" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="#6b6459">breedte op maat &#8212; tot zeer grote vleugels (400 kg)</text>
</svg>
<% } else if (s === 'psk') { %>
<svg viewBox="0 0 460 290" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Kiep-schuifpui: vleugel kantelt naar voren en schuift opzij">
  <defs>
    <linearGradient id="spGlasB" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#e6f1f6"/><stop offset="1" stop-color="#c8dfe9"/>
    </linearGradient>
  </defs>
  <rect x="30" y="24" width="400" height="216" fill="none" stroke="#3a362f" stroke-width="10"/>
  <!-- vast deel links -->
  <rect x="44" y="38" width="182" height="188" fill="url(#spGlasB)" stroke="#3a362f" stroke-width="6"/>
  <line x1="52" y1="46" x2="120" y2="114" stroke="#fff" stroke-width="3" opacity=".55"/>
  <!-- gekantelde vleugel rechts: BOVENZIJDE naar voren (scharnier onder) -->
  <g>
    <polygon points="214,46 422,46 414,230 224,230" fill="url(#spGlasB)" stroke="#161616" stroke-width="9" stroke-linejoin="round"/>
    <line x1="234" y1="62" x2="314" y2="142" stroke="#fff" stroke-width="3" opacity=".55"/>
    <rect x="230" y="126" width="7" height="32" rx="3" fill="#161616"/>
  </g>
  <!-- kiep-pijl (boog) + schuif-pijl -->
  <g stroke="#e8590c" fill="none" stroke-linecap="round">
    <path d="M318 20 q 26 10 24 34" stroke-width="4.5"/>
    <path d="M334 44 342 56 350 41" stroke-width="4.5"/>
    <line x1="352" y1="176" x2="272" y2="176" stroke-width="5"/>
    <path d="M287 163 272 176 287 189" stroke-width="5"/>
  </g>
  <text x="300" y="14" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" fill="#e8590c">1. kiepen</text>
  <text x="312" y="206" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" fill="#e8590c">2. schuiven</text>
  <rect x="30" y="240" width="400" height="10" fill="#3a362f"/>
  <text x="230" y="284" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="#6b6459">kiepstand = veilig ventileren &#183; schuiven = ruime doorgang</text>
</svg>
<% } else if (s === 'alu') { %>
<svg viewBox="0 0 460 290" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Aluminium hef-schuifpui, driedelig: de middenvleugel schuift voor de vaste delen langs">
  <defs>
    <linearGradient id="spGlasC" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#e6f1f6"/><stop offset="1" stop-color="#c8dfe9"/>
    </linearGradient>
  </defs>
  <!-- slank aluminium kader -->
  <rect x="24" y="22" width="412" height="220" fill="none" stroke="#22262c" stroke-width="7"/>
  <!-- vaste delen links en rechts (achterste spoor, smalle stijlen) -->
  <rect x="33" y="31" width="128" height="202" fill="url(#spGlasC)" stroke="#3d434c" stroke-width="3.5"/>
  <rect x="299" y="31" width="128" height="202" fill="url(#spGlasC)" stroke="#3d434c" stroke-width="3.5"/>
  <line x1="42" y1="40" x2="102" y2="100" stroke="#fff" stroke-width="3" opacity=".5"/>
  <line x1="308" y1="40" x2="368" y2="100" stroke="#fff" stroke-width="3" opacity=".5"/>
  <!-- schuivende middenvleugel: loopt V\u00d3\u00d3R de vaste delen (overlapt ze) -->
  <g>
    <rect x="143" y="26" width="174" height="212" fill="url(#spGlasC)" stroke="#22262c" stroke-width="7"/>
    <line x1="156" y1="38" x2="216" y2="98" stroke="#fff" stroke-width="3" opacity=".5"/>
    <rect x="151" y="118" width="6" height="30" rx="3" fill="#22262c"/>
  </g>
  <!-- kan naar links \u00f3f rechts schuiven, over de vaste delen heen -->
  <g stroke="#e8590c" stroke-width="5" fill="none" stroke-linecap="round">
    <line x1="196" y1="132" x2="118" y2="132"/><path d="M132 119 118 132 132 145"/>
    <line x1="264" y1="132" x2="342" y2="132"/><path d="M328 119 342 132 328 145"/>
  </g>
  <rect x="24" y="242" width="412" height="9" fill="#22262c"/>
  <text x="230" y="284" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="#6b6459">middenvleugel schuift v&#243;&#243;r de vaste delen langs &#183; 200+ RAL</text>
</svg>
<% } else if (s === 'latei') { %>
<svg viewBox="0 0 640 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Doorsnede achtergevel: stalen latei draagt het metselwerk boven de vergrote opening voor de schuifpui">
  <defs>
    <linearGradient id="spGlasD" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#e6f1f6"/><stop offset="1" stop-color="#c8dfe9"/>
    </linearGradient>
    <pattern id="spSteen" width="46" height="24" patternUnits="userSpaceOnUse">
      <rect width="46" height="24" fill="#e8ddcb"/>
      <path d="M0 12 H46 M0 24 H46 M23 0 V12 M0 12 V24 M46 12 V24" stroke="#cbbfa8" stroke-width="1.6" fill="none"/>
      <path d="M11.5 12 V24 M34.5 12 V24" stroke="#cbbfa8" stroke-width="0" fill="none"/>
    </pattern>
  </defs>

  <!-- metselwerk boven de opening (verdieping + borstwering) -->
  <rect x="40" y="30" width="560" height="110" fill="url(#spSteen)" stroke="#b7a98e" stroke-width="2"/>
  <!-- penanten links en rechts -->
  <rect x="40" y="140" width="80" height="220" fill="url(#spSteen)" stroke="#b7a98e" stroke-width="2"/>
  <rect x="520" y="140" width="80" height="220" fill="url(#spSteen)" stroke="#b7a98e" stroke-width="2"/>

  <!-- belasting van boven -->
  <g stroke="#6b6459" stroke-width="3" fill="none" stroke-linecap="round">
    <line x1="180" y1="6" x2="180" y2="24"/><path d="M172 16 180 26 188 16"/>
    <line x1="320" y1="6" x2="320" y2="24"/><path d="M312 16 320 26 328 16"/>
    <line x1="460" y1="6" x2="460" y2="24"/><path d="M452 16 460 26 468 16"/>
  </g>
  <text x="320" y="0" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" fill="#6b6459" dy="1">
    <tspan x="545" y="16">gewicht vloer + gevel</tspan>
  </text>

  <!-- STALEN LATEI (I-profiel) met oplegging op beide penanten -->
  <g>
    <rect x="100" y="140" width="440" height="8" fill="#e8590c"/>
    <rect x="286" y="148" width="14" height="26" fill="#e8590c"/>
    <rect x="100" y="174" width="440" height="8" fill="#e8590c"/>
    <rect x="100" y="148" width="8" height="26" fill="#e8590c"/>
    <rect x="532" y="148" width="8" height="26" fill="#e8590c"/>
  </g>
  <!-- opleggingen gemarkeerd -->
  <g stroke="#a13d05" stroke-width="2" stroke-dasharray="5 4" fill="none">
    <rect x="100" y="140" width="20" height="42"/>
    <rect x="520" y="140" width="20" height="42"/>
  </g>

  <!-- nieuwe brede opening met schuifpui -->
  <rect x="128" y="190" width="384" height="164" fill="none" stroke="#3a362f" stroke-width="9"/>
  <rect x="140" y="202" width="176" height="140" fill="url(#spGlasD)" stroke="#3a362f" stroke-width="5"/>
  <rect x="312" y="198" width="190" height="148" fill="url(#spGlasD)" stroke="#161616" stroke-width="7"/>
  <line x1="150" y1="212" x2="210" y2="272" stroke="#fff" stroke-width="3" opacity=".5"/>
  <line x1="324" y1="210" x2="384" y2="270" stroke="#fff" stroke-width="3" opacity=".5"/>
  <g stroke="#e8590c" stroke-width="4.5" fill="none" stroke-linecap="round">
    <line x1="452" y1="272" x2="376" y2="272"/><path d="M390 260 376 272 390 284"/>
  </g>

  <!-- maaiveld -->
  <rect x="20" y="360" width="600" height="8" fill="#3a362f"/>

  <!-- annotaties -->
  <g font-family="'JetBrains Mono',monospace" font-size="11.5" fill="#a13d05">
    <text x="320" y="132" text-anchor="middle" font-weight="600">stalen latei of portaal &#8212; maat volgt uit de constructieberekening</text>
  </g>
  <g font-family="'JetBrains Mono',monospace" font-size="11" fill="#6b6459">
    <text x="80" y="386" text-anchor="middle">penant</text>
    <text x="560" y="386" text-anchor="middle">penant</text>
    <text x="110" y="196" text-anchor="end">oplegging</text>
  </g>
  <!-- maatlijn opening -->
  <g stroke="#6b6459" stroke-width="1.4">
    <line x1="128" y1="404" x2="512" y2="404"/>
    <line x1="128" y1="398" x2="128" y2="410"/><line x1="512" y1="398" x2="512" y2="410"/>
  </g>
  <text x="320" y="419" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="#6b6459">nieuwe, bredere opening</text>
</svg>
<% } %>
