<script>
(function(){
  var f=document.getElementById('spForm');if(!f)return;
  var start=Date.now(), msg=document.getElementById('spMsg'), btn=document.getElementById('spVerstuur');
  f.addEventListener('submit',function(e){
    e.preventDefault();
    msg.className='sp-fmsg';
    var d={elapsed:Date.now()-start};
    ['naam','email','telefoon','adres','plaats','systeem','breedte','hoogte','openingGroter','tekeningHulp','opmerking','website']
      .forEach(function(n){var el=f.querySelector('[name="'+n+'"]');d[n]=el?el.value:'';});
    if(!d.naam.trim()||!d.email.trim()){msg.className='sp-fmsg sp-fout';msg.textContent='Vul in ieder geval uw naam en e-mailadres in.';return;}
    btn.disabled=true;btn.textContent='Versturen\u2026';
    fetch('/schuifpuien/offerte',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)})
      .then(function(r){return r.json().then(function(j){return{ok:r.ok,j:j};});})
      .then(function(r){
        if(r.ok&&r.j.ok){
          msg.className='sp-fmsg sp-ok';
          msg.innerHTML='Dank u wel! Uw aanvraag is ontvangen onder nummer <b>'+r.j.nummer+'</b>. U ontvangt een bevestiging per e-mail en wij nemen binnen \u00e9\u00e9n werkdag contact met u op'+
            (d.tekeningHulp==='ja'?' \u2014 en we starten direct met het opvragen van de gemeentetekening.':'.');
          f.reset();start=Date.now();
        }else{
          msg.className='sp-fmsg sp-fout';msg.textContent=(r.j&&r.j.error)||'Versturen is niet gelukt. Probeer het opnieuw.';
        }
      })
      .catch(function(){msg.className='sp-fmsg sp-fout';msg.textContent='Versturen is niet gelukt. Controleer uw verbinding en probeer het opnieuw.';})
      .finally(function(){btn.disabled=false;btn.textContent='Verstuur aanvraag';});
  });
})();
</script>

<%- include('schuifpui-voet') %>
